# =============================================================================
# .env.example — Template Environment Variables
# Copy ke .env dan isi dengan value yang sesuai:
#   cp .env.example .env
# =============================================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=ecommerce_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC_PURCHASES=ecommerce.purchases
KAFKA_TOPIC_FRAUD_ALERTS=ecommerce.fraud_alerts
KAFKA_CONSUMER_GROUP=ecommerce-pipeline-consumer

DATA_DIR=./data
RAW_CSV_PATH=./data/Ecommerce_Purchases.csv
BATCH_SIZE=1000
KAFKA_PRODUCE_DELAY_SECONDS=0.5
FRAUD_PRICE_THRESHOLD=75.0

DBT_PROFILES_DIR=./dbt
DBT_PROJECT_DIR=./dbt
DBT_TARGET=dev

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
