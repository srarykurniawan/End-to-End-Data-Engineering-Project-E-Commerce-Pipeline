# =============================================================================
# .gitignore — E-Commerce Analytics Pipeline
# =============================================================================

# ── Credentials & Secrets ─────────────────────────────────────────────────────
.env
*.key
*.pem
*.p12

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.python-version
*.egg-info/
dist/
build/

# ── dbt ───────────────────────────────────────────────────────────────────────
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml

# ── Airflow ───────────────────────────────────────────────────────────────────
logs/
airflow.db
airflow.cfg
webserver_config.py

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Data Files ────────────────────────────────────────────────────────────────
data/*.csv
data/*.parquet
data/*.json
# Biarkan folder data/ tapi abaikan isinya (kecuali .gitkeep)
!data/.gitkeep

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Spark ─────────────────────────────────────────────────────────────────────
spark-warehouse/
derby.log
metastore_db/
/tmp/spark-checkpoints/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.log
